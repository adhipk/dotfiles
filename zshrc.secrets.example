# Copy this to ~/.zshrc.secrets (or to ./zshrc.secrets for local testing) and
# fill in your own values. This file is sourced by zshrc if present.

# Claude Code + AWS Bedrock
export CLAUDE_CODE_USE_BEDROCK=1
export AWS_REGION=us-west-2
export AWS_PROFILE="your-aws-profile"
export ANTHROPIC_MODEL="global.anthropic.claude-sonnet-4-5-20250929-v1:0"
export ANTHROPIC_SMALL_FAST_MODEL="us.anthropic.claude-3-haiku-20240307-v1:0"
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=4096
export MAX_THINKING_TOKENS=1024
export ZED_AWS_PROFILE="$AWS_PROFILE"

# API keys (examples)
# export OPENAI_API_KEY="..."
# export ANTHROPIC_API_KEY="..."
